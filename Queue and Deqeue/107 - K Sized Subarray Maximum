import collections
class Solution:
    def maxOfSubarrays(self, arr, k):
        output=[]
        q=collections.deque()
        l=r=0
        
        while(r<len(arr)):
            while q and arr[q[-1]]<arr[r]:
                q.pop()
            q.append(r)
        
            while q and q[0]<l:
                q.popleft()
            
            if (r+1)>=k:
                output.append(arr[q[0]])
                l+=1
            r+=1
        return output
