class Solution:
    def nextLargerElement(self, arr):
        # code here
        n=len(arr)
        result=[-1]*n
        stack=[]
        for i in range(len(arr)):
            while stack and arr[i]>arr[stack[-1]]:
                idx=stack.pop()
                result[idx]=arr[i]
            stack.append(i)
        return result
