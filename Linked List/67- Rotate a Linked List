class Solution {
    public Node rotate(Node head, int k) {
        // code here
        if(head==null|| head.next==null ||k==0)
        {
            return head;
        }
        Node current=head;
        Node end=head;
        int length=1;
        while(end.next!=null )
        {
            end=end.next;
            length++;
            
        }
        k=k%length;
        
        if(k==0)
        return head;
        int i=1;
        while(i<k && current!=null){
            current=current.next;
            i++;
        }
        if(current==null || current.next ==null)
            return head;
        Node newHead=current.next;
        current.next=null;
        end.next=head;
        
        return newHead;
    }
}
