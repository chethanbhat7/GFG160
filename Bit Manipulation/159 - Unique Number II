#User function Template for python3

class Solution:
	def singleNum(self, arr):
		repeatedonce=set()
		repeatedtwice=set()
		
		for i in arr:
		    if i not in repeatedonce:
		        repeatedonce.add(i)
            else:
                repeatedtwice.add(i)
        
        retarr=sorted(list(repeatedonce-repeatedtwice))
        
        return retarr
