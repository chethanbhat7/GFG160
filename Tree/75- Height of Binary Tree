'''
Definition for Node
class Node:
    def _init_(self, val):
        self.data = val
        self.left = None
        self.right = None
'''

class Solution:
    def height(self, root):
        # code here
        if root is None:
            return -1
            
        leftheight=self.height(root.left)
        rightheight=self.height(root.right)
        
        return max(leftheight,rightheight)+1
