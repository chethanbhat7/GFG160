class Solution:
    def maxWater(self, arr):
        l=0
        r=len(arr)-1
        m=0
        while(l<r):
            if (min(arr[l],arr[r])*(r-l))>m:
                m=min(arr[l],arr[r])*(r-l)
            if(arr[l]<arr[r]):
                l+=1
            else:
                r-=1
            
        return m
