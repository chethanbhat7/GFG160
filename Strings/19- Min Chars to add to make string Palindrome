class Solution:
    def minChar(self, s):
        rev=s[::-1]
        temp=s+'#'+rev
        
        lps=[0]*len(temp)
        
        i=1
        j=0
        
        while i <len(temp):
            if temp[i]==temp[j]:
                j+=1
                lps[i]=j
                i+=1
            else:
                if j!=0:
                    j=lps[j-1]
                else:
                    lps[i]=0
                    i+=1
        return len(s)-lps[-1]
